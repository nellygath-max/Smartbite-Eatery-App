PORT=3000
HOST=0.0.0.0
# Comma-separated list of allowed frontend origins for CORS.
# Example: CORS_ORIGINS=http://192.168.1.5:5173,http://localhost:5173
CORS_ORIGINS=
MONGO_URI=mongodb://127.0.0.1:27017/smartbite
# Atlas deployments can use a URI without a database path; this selects the
# database explicitly in either case.
MONGO_DB_NAME=SmartbiteEateryApp
# Generate a unique random value for each environment, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Must be a unique, random value of at least 32 characters. Do not use this placeholder.
JWT_SECRET=replace-with-a-unique-random-secret
JWT_ISSUER=smartbite-api
JWT_AUDIENCE=smartbite-api-client
JWT_EXPIRES_IN=1d
# Cloudinary credentials for menu image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
